# ─────────────────────────────────────────────────────────────────────────────
# OpenCode-in-ClaudeCode configuration. Copy this file to `.env` and fill in.
# The installer (setup.sh / setup.ps1) will copy it to ~/.claude/claude-oc.env
# and the shell/PowerShell functions read it at session start.
# ─────────────────────────────────────────────────────────────────────────────

# === OpenCode Go (Anthropic endpoint — direct, no proxy) =====================
# Get a key at https://opencode.ai/auth (subscribe to "Go").
OPENCODE_GO_KEY=""
OPENCODE_GO_BASE_URL="https://opencode.ai/zen/go"

# Models served on opencode's Anthropic /v1/messages endpoint.
# Used by `claude-oc` and `claude-oc-init`. Override inline with: OPUS=qwen3.7-max claude-oc
OC_OPUS_MODEL="minimax-m3"
OC_OPUS_NAME="MiniMax M3"
OC_SONNET_MODEL="qwen3.7-max"
OC_SONNET_NAME="Qwen 3.7 Max"
OC_HAIKU_MODEL="minimax-m3"
OC_HAIKU_NAME="MiniMax M3"
OC_SUBAGENT_MODEL="minimax-m3"

# === OpenCode Go (OpenAI endpoint — via local proxy) =========================
# Models served on opencode's OpenAI /v1/chat/completions endpoint
# (GLM, Kimi, DeepSeek, MiMo). Used by `claude-px` and `claude-px-init`.
# The proxy at ~/.claude/oc-proxy.js translates Anthropic<->OpenAI in real time.
PX_OPUS_MODEL="glm-5.2"
PX_OPUS_NAME="GLM 5.2"
PX_SONNET_MODEL="glm-5.2"
PX_SONNET_NAME="GLM 5.2"
PX_HAIKU_MODEL="glm-5.2"
PX_HAIKU_NAME="GLM 5.2"
PX_SUBAGENT_MODEL="glm-5.2"

# Port for the local proxy (Claude Code -> proxy -> opencode OpenAI endpoint).
PX_PORT="8322"

# === LiteLLM (your own gateway) =============================================
# Point at a LiteLLM proxy you already run. LiteLLM speaks OpenAI /chat/completions
# and the Anthropic-compatible /v1/messages endpoint depending on config; this
# project uses the Anthropic endpoint so Claude Code works directly.
#   - Remote:  https://llm.mesbahuddin.com
#   - Local:   http://localhost:5001
LITELLM_BASE_URL="https://llm.mesbahuddin.com"
# LiteLLM virtual key (master key or a issued key). Leave blank if your gateway
# has no auth.
LITELLM_API_KEY=""
# LiteLLM model aliases (the model_name values in your litellm-config.yaml).
# The opus/sonnet/haiku slots are what Claude Code's /model picker maps to.
LITELLM_OPUS_MODEL="opencode-go/glm-5.2"
LITELLM_OPUS_NAME="GLM 5.2 (LiteLLM)"
LITELLM_SONNET_MODEL="opencode-go/minimax-m3"
LITELLM_SONNET_NAME="MiniMax M3 (LiteLLM)"
LITELLM_HAIKU_MODEL="groq/llama-3.3-70b-versatile"
LITELLM_HAIKU_NAME="Llama 3.3 70B (Groq)"
LITELLM_SUBAGENT_MODEL="opencode-go/glm-5.2"

# LiteLLM speaks BOTH endpoints:
#   /v1/messages         (Anthropic)  — works for Groq/Gemini/OpenRouter/Ollama/vLLM
#   /v1/chat/completions  (OpenAI)     — works for ALL models including opencode-go/*
#
# claude-litellm calls /v1/messages directly by default (LITELLM_USE_PROXY=0).
# Set LITELLM_USE_PROXY=1 ONLY if your LITELLM_*_MODEL values include opencode-go/*
# models (LiteLLM's /v1/messages route 404s for those — the upstream base URL is
# the OpenAI endpoint). The proxy routes through LiteLLM's /v1/chat/completions.
LITELLM_USE_PROXY="0"